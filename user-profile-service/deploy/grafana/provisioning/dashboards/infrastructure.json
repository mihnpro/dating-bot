{
  "uid": "dating-infrastructure",
  "title": "Dating Bot — Infrastructure",
  "tags": ["dating-bot", "infrastructure", "rabbitmq", "redis", "go-runtime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "RabbitMQ — Messages Published / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(rabbitmq_channel_messages_published_total[1m]))", "legendFormat": "published/s", "refId": "A" },
        { "expr": "sum(rate(rabbitmq_channel_messages_delivered_total[1m]))", "legendFormat": "delivered/s", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "title": "RabbitMQ — Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum by (queue) (rabbitmq_queue_messages_ready)", "legendFormat": "{{queue}} ready", "refId": "A" },
        { "expr": "sum by (queue) (rabbitmq_queue_messages_unacked)", "legendFormat": "{{queue}} unacked", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 3,
      "title": "RabbitMQ — Connections & Channels",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rabbitmq_connections", "legendFormat": "connections", "refId": "A" },
        { "expr": "rabbitmq_channels", "legendFormat": "channels", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 4,
      "title": "RabbitMQ — Consumer Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum by (queue) (rabbitmq_queue_consumers)", "legendFormat": "{{queue}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 5,
      "title": "Go Goroutines (all services)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "go_goroutines", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "title": "Go Heap Alloc (all services, MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "go_memstats_heap_alloc_bytes / 1024 / 1024", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "MB", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "title": "Go GC Pause Duration (all services)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        { "expr": "rate(go_gc_duration_seconds_sum[1m]) / rate(go_gc_duration_seconds_count[1m])", "legendFormat": "{{service}} avg GC pause", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "title": "Go Open File Descriptors (all services)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "process_open_fds", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 9,
      "title": "Loki — Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum by (service) (rate({job=\"docker\"}[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    }
  ]
}
