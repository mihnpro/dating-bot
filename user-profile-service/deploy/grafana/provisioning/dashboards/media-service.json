{
  "uid": "dating-media",
  "title": "Dating Bot — Media Service",
  "tags": ["dating-bot", "media"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Uploads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "media_uploads_total{service=\"media-service\"}", "legendFormat": "uploads", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2,
      "title": "Upload Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "media_upload_errors_total{service=\"media-service\"}", "legendFormat": "errors", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Upload Success Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "media_uploads_total{service=\"media-service\"} / (media_uploads_total{service=\"media-service\"} + media_upload_errors_total{service=\"media-service\"}) * 100",
          "legendFormat": "success %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 90 }, { "color": "green", "value": 98 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "Service Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "up{job=\"media-service\"}", "legendFormat": "status", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "Upload Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "rate(media_uploads_total{service=\"media-service\"}[1m])", "legendFormat": "uploads/s", "refId": "A" },
        { "expr": "rate(media_upload_errors_total{service=\"media-service\"}[1m])", "legendFormat": "errors/s", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "title": "HTTP Request Rate by Path",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (method, path) (rate(http_requests_total{service=\"media-service\"}[1m]))",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "title": "HTTP Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"media-service\"}[1m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"media-service\"}[1m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"media-service\"}[1m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "title": "HTTP Error Rate by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total{service=\"media-service\", status=~\"4..|5..\"}[1m]))",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 9,
      "title": "Go Runtime",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "expr": "go_goroutines{service=\"media-service\"}", "legendFormat": "goroutines", "refId": "A" },
        { "expr": "go_memstats_heap_alloc_bytes{service=\"media-service\"} / 1024 / 1024", "legendFormat": "heap MB", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 10,
      "title": "Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "{service=\"media-service\"}", "refId": "A", "datasource": { "type": "loki", "uid": "loki" } }
      ],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
