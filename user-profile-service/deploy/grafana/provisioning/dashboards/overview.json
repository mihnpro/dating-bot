{
  "uid": "dating-overview",
  "title": "Dating Bot — Overview",
  "tags": ["dating-bot", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        { "expr": "up{job=~\"user-profile-service|matching-service|recommendation-service|chat-service|media-service\"}", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Total RPS (all services)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum by (service) (rate(grpc_server_requests_total[1m]))", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 3,
      "title": "p95 Latency (all services)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (service, le) (rate(grpc_server_request_duration_seconds_bucket[1m])))", "legendFormat": "{{service}} p95", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 4,
      "title": "gRPC Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (service) (rate(grpc_server_requests_total{code!=\"OK\"}[1m])) / sum by (service) (rate(grpc_server_requests_total[1m])) * 100",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2 }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 5,
      "title": "In-Flight gRPC Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "grpc_server_in_flight_requests", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 6,
      "title": "New Registrations / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "targets": [
        { "expr": "rate(dating_users_registered_total[1m]) * 60", "legendFormat": "users/min", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 7,
      "title": "Likes / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "targets": [
        { "expr": "rate(dating_interactions_total{type=\"like\"}[1m]) * 60", "legendFormat": "likes/min", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 8,
      "title": "Matches / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "targets": [
        { "expr": "rate(dating_matches_created_total[1m]) * 60", "legendFormat": "matches/min", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 9,
      "title": "Messages Sent / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "targets": [
        { "expr": "rate(chat_messages_total[1m]) * 60", "legendFormat": "msgs/min", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    }
  ]
}
