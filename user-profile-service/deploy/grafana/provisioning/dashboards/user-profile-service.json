{
  "uid": "dating-user-profile",
  "title": "Dating Bot — User Profile Service",
  "tags": ["dating-bot", "user-profile"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Users Registered (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "dating_users_registered_total", "legendFormat": "total", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2,
      "title": "Profiles Created (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "dating_profiles_created_total", "legendFormat": "total", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 3,
      "title": "Profiles Updated (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "dating_profiles_updated_total", "legendFormat": "total", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 4,
      "title": "Service Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "up{job=\"user-profile-service\"}", "legendFormat": "status", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "Registration Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "rate(dating_users_registered_total[5m])", "legendFormat": "registrations/s", "refId": "A" },
        { "expr": "rate(dating_profiles_created_total[5m])", "legendFormat": "profiles created/s", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "title": "Profile Fullness Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "increase(dating_profile_fullness_bucket[24h])", "legendFormat": "{{le}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "gRPC Request Rate by Method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (method) (rate(grpc_server_requests_total{service=\"user-profile-service\"}[1m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "title": "gRPC Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(grpc_server_request_duration_seconds_bucket{service=\"user-profile-service\"}[1m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(grpc_server_request_duration_seconds_bucket{service=\"user-profile-service\"}[1m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(grpc_server_request_duration_seconds_bucket{service=\"user-profile-service\"}[1m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 9,
      "title": "gRPC Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (code) (rate(grpc_server_requests_total{service=\"user-profile-service\", code!=\"OK\"}[1m]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 }, "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 10,
      "title": "Go Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "go_goroutines{service=\"user-profile-service\"}", "legendFormat": "goroutines", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 11,
      "title": "Go Heap Memory (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        { "expr": "go_memstats_heap_alloc_bytes{service=\"user-profile-service\"} / 1024 / 1024", "legendFormat": "heap alloc MB", "refId": "A" },
        { "expr": "go_memstats_heap_inuse_bytes{service=\"user-profile-service\"} / 1024 / 1024", "legendFormat": "heap inuse MB", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "MB", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 12,
      "title": "Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        { "expr": "{service=\"user-profile-service\"}", "refId": "A", "datasource": { "type": "loki", "uid": "loki" } }
      ],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
